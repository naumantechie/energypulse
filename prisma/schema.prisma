generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Country {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  continent     String
  population    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  energyRecords EnergyRecord[]
}

model EnergyRecord {
  id               String   @id @default(cuid())
  countryId        String
  year             Int
  solarGwh         Float
  windGwh          Float
  hydroGwh         Float
  nuclearGwh       Float
  fossilGwh        Float
  totalGwh         Float
  renewablePercent Float
  carbonIntensity  Float
  createdAt        DateTime @default(now())
  country          Country  @relation(fields: [countryId], references: [id])

  @@unique([countryId, year])
  @@index([countryId])
  @@index([year])
}

model LiveGrid {
  id               String   @id @default(cuid())
  countryCode      String   @unique
  carbonIntensity  Float
  renewablePercent Float
  fossilPercent    Float
  syncedAt         DateTime @default(now())

  @@index([countryCode])
}
